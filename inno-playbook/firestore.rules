rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function userRole() {
      // .get() ป้องกัน crash กรณี document ยังไม่มี (first-time register)
      return isAuth()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'member')
        : 'guest';
    }

    function isSuperAdmin() {
      return userRole() == 'super_admin';
    }

    function isOrgAdmin() {
      return userRole() in ['super_admin', 'org_admin'];
    }

    function canEdit() {
      return isAuth() && userRole() in ['super_admin', 'org_admin', 'facilitator', 'member'];
    }

    // ── users/{uid} ───────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── organizations/{orgId} ─────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read:           if isAuth();
      allow create, update: if canEdit();
      allow delete:         if isOrgAdmin();
    }

    // ── deliverables/{deliverableId} ──────────────────────────────────────────
    match /deliverables/{deliverableId} {
      allow read:           if isAuth();
      allow create, update: if canEdit();
      allow delete:         if isOrgAdmin();
    }

    // ── presence/{orgId}/users/{userId} ───────────────────────────────────────
    // Authenticated users can write/read their own presence
    match /presence/{orgId}/users/{userId} {
      allow read:   if isAuth();
      allow write:  if isOwner(userId);
    }

    // ── activities/{orgId}/feed/{actId} ───────────────────────────────────────
    // Authenticated users can read all; write if they are the author
    match /activities/{orgId}/feed/{actId} {
      allow read:   if isAuth();
      allow create: if canEdit();
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── comments/{docId}/items/{commentId} ───────────────────────────────────
    // Authenticated can read; write own; delete own
    match /comments/{docId}/items/{commentId} {
      allow read:   if isAuth();
      allow create: if canEdit();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid || isSuperAdmin()
      );
    }

    // ── versions/{docId}/history/{versionId} ─────────────────────────────────
    // Authenticated can read; write if they can edit
    match /versions/{docId}/history/{versionId} {
      allow read:   if isAuth();
      allow create: if canEdit();
      allow update, delete: if isSuperAdmin();
    }

    // ── notifications/{userId}/items/{notifId} ────────────────────────────────
    // Users can only read/write their own notifications
    match /notifications/{userId}/items/{notifId} {
      allow read, write: if isOwner(userId);
      // Allow super_admin and system to create notifications for any user
      allow create: if isAuth() && isSuperAdmin();
    }

    // ── cohorts/{cohortId} ────────────────────────────────────────────────────
    // Authenticated can read; org_admin+ can create/update; super_admin can delete
    match /cohorts/{cohortId} {
      allow read:           if isAuth();
      allow create, update: if isOrgAdmin();
      allow delete:         if isSuperAdmin();
    }
  }
}
