rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function userRole() {
      // .get() ป้องกัน crash กรณี document ยังไม่มี (first-time register)
      return isAuth()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'member')
        : 'guest';
    }

    function isSuperAdmin() {
      return userRole() == 'super_admin';
    }

    function isOrgAdmin() {
      return userRole() in ['super_admin', 'org_admin'];
    }

    function canEdit() {
      return isAuth() && userRole() in ['super_admin', 'org_admin', 'facilitator', 'member'];
    }

    // super_admin shortcut — ถ้า userRole() ล้มเหลว (doc ยังไม่มี) ให้ super_admin ผ่านได้
    function isSuperAdminSafe() {
      return isAuth() && (
        isSuperAdmin() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role','') == 'super_admin'
      );
    }

    // ── users/{uid} ───────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── organizations/{orgId} ─────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read:           if isAuth();
      allow create, update: if canEdit();
      allow delete:         if isOrgAdmin();
    }

    // ── deliverables/{deliverableId} ──────────────────────────────────────────
    match /deliverables/{deliverableId} {
      allow read:           if isAuth();
      allow create, update: if canEdit();
      allow delete:         if isOrgAdmin();
    }

    // ── presence/{orgId}/users/{userId} ───────────────────────────────────────
    // Authenticated users can write/read their own presence
    match /presence/{orgId}/users/{userId} {
      allow read:   if isAuth();
      allow write:  if isOwner(userId);
    }

    // ── activities/{orgId}/feed/{actId} ───────────────────────────────────────
    // Authenticated users can read all; write if they are the author
    match /activities/{orgId}/feed/{actId} {
      allow read:   if isAuth();
      allow create: if canEdit();
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── comments/{docId}/items/{commentId} ───────────────────────────────────
    // Authenticated can read; write own; delete own
    match /comments/{docId}/items/{commentId} {
      allow read:   if isAuth();
      allow create: if canEdit();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid || isSuperAdmin()
      );
    }

    // ── versions/{docId}/history/{versionId} ─────────────────────────────────
    // Authenticated can read; write if they can edit
    match /versions/{docId}/history/{versionId} {
      allow read:   if isAuth();
      allow create: if canEdit();
      allow update, delete: if isSuperAdmin();
    }

    // ── notifications/{userId}/items/{notifId} ────────────────────────────────
    // Users can only read/write their own notifications
    match /notifications/{userId}/items/{notifId} {
      allow read, write: if isOwner(userId);
      // Allow super_admin and system to create notifications for any user
      allow create: if isAuth() && isSuperAdmin();
    }

    // ── cohorts/{cohortId} ────────────────────────────────────────────────────
    // Authenticated can read; org_admin+ can create/update; super_admin can delete
    match /cohorts/{cohortId} {
      allow read:           if isAuth();
      allow create, update: if isOrgAdmin();
      allow delete:         if isSuperAdmin();
    }

    // ── health_snapshots/{orgId}/snapshots/{snapId} ───────────────────────────
    // Org members can read/write their own health snapshots; admins can read all
    match /health_snapshots/{orgId}/snapshots/{snapId} {
      allow read:   if isAuth();
      allow create: if canEdit();
      allow update, delete: if isSuperAdmin();
    }

    // ── experts/{expertId} ───────────────────────────────────────────────────
    // All authenticated users can read; only admins/facilitators can write
    match /experts/{expertId} {
      allow read:           if isAuth();
      allow create, update: if isOrgAdmin();
      allow delete:         if isSuperAdmin();
    }

    // ── connections/{connectionId} ───────────────────────────────────────────
    // Users can read their own; admins can read all; authenticated users can create
    match /connections/{connectionId} {
      allow read:   if isAuth() && (
        resource.data.userId == request.auth.uid || isSuperAdmin()
      );
      allow create: if canEdit();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── canvases/{orgId}/nodes/{nodeId} ──────────────────────────────────────
    // Authenticated org members can read/write canvas nodes
    match /canvases/{orgId}/nodes/{nodeId} {
      allow read:   if isAuth();
      allow create: if canEdit();
      allow update: if canEdit();
      allow delete: if isAuth() && (
        resource.data.createdBy == request.auth.uid || isOrgAdmin()
      );
    }

    // ── initiatives/{initiativeId} ────────────────────────────────────────────
    match /initiatives/{initiativeId} {
      allow read:   if isAuth();
      allow create: if isSuperAdminSafe() || canEdit();
      allow update: if isSuperAdminSafe() || (isAuth() && (
        resource.data.ownerId == request.auth.uid || isOrgAdmin()
      ));
      allow delete: if isSuperAdminSafe() || (isAuth() && (
        resource.data.ownerId == request.auth.uid || isOrgAdmin()
      ));
    }

    // ── community_ideas/{ideaId} ──────────────────────────────────────────────
    // Org members can read; authenticated users can create; owner can update/delete
    match /community_ideas/{ideaId} {
      allow read:   if isAuth();
      allow create: if canEdit();
      allow update: if isAuth() && (
        resource.data.authorId == request.auth.uid ||
        isOrgAdmin() ||
        // Allow vote updates (votes field only)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes'])
      );
      allow delete: if isAuth() && (
        resource.data.authorId == request.auth.uid || isOrgAdmin()
      );
    }

    // ── community_discussions/{threadId} ──────────────────────────────────────
    match /community_discussions/{threadId} {
      allow read:   if isAuth();
      allow create: if canEdit();
      allow update: if isAuth() && (
        resource.data.authorId == request.auth.uid || isOrgAdmin()
      );
      allow delete: if isAuth() && (
        resource.data.authorId == request.auth.uid || isOrgAdmin()
      );
    }

    // ── community_discussions/{threadId}/replies/{replyId} ───────────────────
    match /community_discussions/{threadId}/replies/{replyId} {
      allow read:   if isAuth();
      allow create: if canEdit();
      allow delete: if isAuth() && (
        resource.data.authorId == request.auth.uid || isOrgAdmin()
      );
    }
  }
}
